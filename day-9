  use dap25;

select * from dataset ;
select * from customer_segmentation_data;

-- Windows functions / Sub-query / Common table expression 

--  max , min , avg , sum , count  of medical charges for each region ? 
select max(`medical charges`)  , min(`medical charges`), count(*) , 
avg(`medical charges`), sum(`medical charges`) 
from dataset 
-- where region ='southeast';
group by region;

select * , 
row_number() over() as r_number,
rank() over() as rn,
dense_rank() over() as d_rn
from dataset;
-- rank(), dence_rank()

-- Order by medical charges desc / asc 

select * , 
row_number() over(order by `medical charges` desc) as r_number,
rank() over(order by `medical charges` desc) as rn,
dense_rank() over(order by `medical charges` desc) as d_rn
from dataset;


-- Order by age desc / asc 

select * , 
row_number() over(order by age desc) as r_number,
rank() over(order by age desc) as rn,
dense_rank() over(order by age desc) as d_rn
from dataset;


-- Order by BMI desc / asc 

select * , 
row_number() over(order by BMI desc) as r_number,
rank() over(order by BMI desc) as rn,
dense_rank() over(order by BMI desc) as d_rn
from dataset;


