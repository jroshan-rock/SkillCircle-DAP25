-- partition by  => group by smoker 

with smoker_limit200 as (
select * from dataset limit 200
)
select * , 
row_number() over(partition by smoker) as r_number,
rank() over(partition by smoker) as rn,
dense_rank() over(partition by smoker) as d_rn
from smoker_limit200;

-- Partition by region  with medical charges is desc

with smoker_limit200 as (
select * from dataset limit 200
)

select * , 
row_number() over(partition by region order by `medical charges` desc) as r_number,
rank() over(partition by region order by `medical charges` desc) as rn,
dense_rank() over( partition by region order by `medical charges` desc) as d_rn
from smoker_limit200;

