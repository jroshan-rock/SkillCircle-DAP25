-- Between and in 
1. The SQL in operator is a logical operator used in the where clause to specific multiple values for a column. 
It allows you to filter based on whether a columns' values mathces any within a specificed list or the result of a subquery.

1. Between is a logical opertor used for filter record based on specific range . 

-- Age should be more than 18 and less than 35 for smoker is yes;
select * from dataset where age > 18 and age <35 and smoker= 'yes'
order by `medical charges` desc;

-- Age should be more than 18 or less than 35 for smoker is yes;
select * from dataset where (age > 18 or age <35) and smoker= 'yes'
order by `medical charges` desc;

-- Range  ( between ) 
select * from dataset where (age >= 18 and age <=35) and smoker= 'yes'
order by `medical charges` desc;

select * from dataset where age between 18 and 35 and smoker= 'yes'
order by `medical charges` desc;

-- Between  ( use for filtring range value like age , date/time etc ) 
SELECT COUNT(*) FROM medical_costs 
WHERE Age BETWEEN 18 AND 25;

👉 BETWEEN is inclusive — it includes both the boundary values.
So this query counts all rows where
Age >= 18 AND Age <= 25.

SELECT COUNT(*) FROM medical_costs 
WHERE Age > 18 AND Age < 25;

👉 This query is exclusive — it does not include 18 and 25.
It only counts rows where
Age is strictly greater than 18 and strictly less than 25.

select * from medical_costs where Age between 25 and 30;


