CREATE TABLE Customer_info (
    CustomerID int NOT NULL PRIMARY KEY AUTO_INCREMENT,
    Name varchar(255) NOT NULL,
    Age int CHECK (Age >= 18),
    City varchar(255) DEFAULT 'Mumbai',
    UNIQUE (Name) , 
    email varchar(50) not null unique 
);
